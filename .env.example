# Newo Search Ads — Environment Variables
# Copy to ~/.newo-ads.env and fill in values

# Google Ads API
GOOGLE_ADS_DEVELOPER_TOKEN=           # from Google Ads → Tools → API Center
GOOGLE_ADS_CLIENT_ID=                 # OAuth2 client ID from Google Cloud Console
GOOGLE_ADS_CLIENT_SECRET=             # OAuth2 client secret
GOOGLE_ADS_REFRESH_TOKEN=             # run: python3 scripts/get_refresh_token.py
GOOGLE_ADS_CUSTOMER_ID=               # 10-digit ID without dashes (e.g. 1234567890)
GOOGLE_ADS_LOGIN_CUSTOMER_ID=         # MCC/manager account ID if applicable (else same as above)

# Anthropic (Claude for report generation)
ANTHROPIC_API_KEY=sk-ant-...

# Slack (for posting reports)
SLACK_WEBHOOK_URL=                    # Slack App → Incoming Webhooks

# Optimization targets
TARGET_CPA=50                         # target cost per conversion in dollars
TARGET_ROAS=4.0                       # target return on ad spend multiplier
